# ----------------------------------------------------------------------------
# EnerjiOne DNP3 Gateway - ornek ortam degiskenleri
# (Horstmann SN2 cihazlarindan DNP3 ile veri toplayip NATS JetStream'e basar.)
# Bu dosyayi .env olarak kopyalayip kendi ortaminiza gore duzenleyin.
# ----------------------------------------------------------------------------

# Gateway kimligi (backend'deki gateways tablosu ile eslesmeli)
GATEWAY_CODE=GW-001
# Uretimde: minimum 32 karakter, rastgele; asla repoda paylasmayin (Secret / Windows DPAPI)
GATEWAY_TOKEN=gw-001-token
GATEWAY_NAME=EnerjiOne DNP3 Gateway 01

# Ortam: development | staging | production (kisa: dev, stg, prod)
# Uretimde development KULLANMAYIN; token uzunlugu + placeholder kontrolleri acilir.
APP_ENVIRONMENT=development

# Production'da public IP/hostname icin clear-text http://+nats:// yasak —
# validator reddeder. TLS henuz kurulamiyorsa (orn. backend hala public IP'de,
# Caddy/LE eklenmedi) BILINCLI opt-out yapabilirsiniz. Default FALSE. Boot'ta
# loud WARN log atilir. Sadece TLS kurulana kadar gecici saha icin.
# GATEWAY_INSECURE_ALLOW_PLAINTEXT=true

# Opsiyonel: servis ornegi UUID (bos birakilirsa GATEWAY_STATE_DIR altina otomatik yazilir)
# GKE / Docker: pod name veya task id vermek icin set edilebilir.
# GATEWAY_INSTANCE_ID=

# Kalici instance id dosyasi (coklu gateway ayni VM'de: her GATEWAY_CODE icin ayri dosya)
GATEWAY_STATE_DIR=.gateway_state

# Calisma modu: mock | dnp3
#   mock -> gercek DNP3 olmadan, mantikli rastgele deger uretir (gelistirme)
#   dnp3 -> gercek cihazlara TCP uzerinden DNP3 master baglantisi kurar
GATEWAY_MODE=mock

# Backend API
BACKEND_API_URL=http://127.0.0.1:8000/api/v1
# TLS: kendi CA'niz varsa bundle yolu; yoksa dogrulama sistem store + BACKEND_API_VERIFY_SSL=true
BACKEND_API_VERIFY_SSL=true
# BACKEND_API_CA_PATH=C:\certs\corp-root.pem
CONFIG_REFRESH_SEC=30
CONFIG_TIMEOUT_SEC=5

# NATS JetStream (gateway'in PRIMARY telemetri yayinlama yolu — ZORUNLU)
# Gateway artik tum telemetriyi DIRECT JetStream'e basar. NATS_URL erisilemezse
# gateway yine ayaga kalkar, mesajlar outbox'a yazilir, baglanti gelince retrier
# bosaltir — mesaj kaybi YOK. Subject: e1.telemetry.raw.<GATEWAY_CODE>
NATS_URL=nats://localhost:4222
NATS_SUBJECT_PREFIX=e1.telemetry.raw
NATS_CONNECT_TIMEOUT_SEC=5
NATS_PUBLISH_TIMEOUT_SEC=2.0

# RabbitMQ — gateway artik kullanmiyor (alarm akisi backend'de RabbitMQ'da
# kalmaya devam ediyor; gateway onunla ilgilenmez). Bos birakin.
# Eski deploylar icin geriye uyumluluk amaciyla saklaniyor.
RABBITMQ_URL=
RABBITMQ_EXCHANGE=e1.events
RABBITMQ_ROUTING_KEY=telemetry.raw_received

# Health HTTP endpoint
WORKER_HEALTH_HOST=127.0.0.1
WORKER_HEALTH_PORT=8020

# Polling
DEFAULT_POLL_INTERVAL_SEC=5
MAX_PARALLEL_DEVICES=25

# DNP3 master parametreleri (GATEWAY_MODE=dnp3 icin)
DNP3_LOCAL_ADDRESS=1
DNP3_TCP_PORT=20000
DNP3_INTEGRITY_POLL_MIN=60
DNP3_RESPONSE_TIMEOUT_SEC=5

# Loglama
LOG_LEVEL=INFO
LOG_FORMAT=text
# Baslangicta konsolda token: true=tam metin, false=maskeli (uretimde false onerilir)
SHOW_GATEWAY_TOKEN_ON_START=true
