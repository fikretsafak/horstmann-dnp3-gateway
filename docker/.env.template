# Horstmann Smart Logger DNP3 Gateway — per-instance .env (Docker)
#
# Bu dosyayi `.env.<GATEWAY_CODE>` olarak kopyalayip degerleri doldurun.
# `docker run --env-file .env.GW-001 ...` veya compose'taki `env_file:` ile yuklenir.
#
# Sablon yer tutuculari:
#   {{...}} ile isaretli alanlar render zamani doldurulur (backend veya
#   scripts/render_compose.py).

# ----- Gateway kimligi -------------------------------------------------------
GATEWAY_CODE={{GATEWAY_CODE}}
GATEWAY_TOKEN={{GATEWAY_TOKEN}}
GATEWAY_NAME={{GATEWAY_NAME}}
APP_ENVIRONMENT={{APP_ENVIRONMENT}}

# ----- Calisma modu ----------------------------------------------------------
GATEWAY_MODE=dnp3
DNP3_LIBRARY=yadnp3

# ----- Backend ---------------------------------------------------------------
BACKEND_API_URL={{BACKEND_API_URL}}
BACKEND_API_VERIFY_SSL=true
CONFIG_REFRESH_SEC=30

# ----- NATS JetStream (PRIMARY — gateway'in tek telemetri yayinlama yolu) ---
# Subject: e1.telemetry.raw.<GATEWAY_CODE>. NATS erisilemezse gateway yine
# ayaga kalkar, mesajlar outbox'a yazilir, baglanti gelince retrier bosaltir
# — mesaj kaybi yok.
NATS_URL={{NATS_URL}}
NATS_SUBJECT_PREFIX=e1.telemetry.raw

# ----- Health/metric HTTP (container ici) -----------------------------------
WORKER_HEALTH_HOST=0.0.0.0
WORKER_HEALTH_PORT=8020

# ----- Polling ---------------------------------------------------------------
DEFAULT_POLL_INTERVAL_SEC=5
MAX_PARALLEL_DEVICES=50

# ----- DNP3 ------------------------------------------------------------------
DNP3_LOCAL_ADDRESS=1
DNP3_TCP_PORT=20000
DNP3_RESPONSE_TIMEOUT_SEC=8
DNP3_READ_STRATEGY=event_driven
DNP3_EVENT_BASELINE_INTERVAL_SEC=60

# ----- Logging ---------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
SHOW_GATEWAY_TOKEN_ON_START=false
